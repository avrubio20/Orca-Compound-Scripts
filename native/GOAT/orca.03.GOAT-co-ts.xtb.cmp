# orca.03.GOAT-co-ts.xtb.cmp
#
# Author:  Aris V. Rubio
# Date  :  July 2026
# ---------------------------------------------------------
# Jobs:
#   01  GOAT constrained conformer search
#   02  Constrained pre-opt loop
#   03  TS optimization loop

# --- System ---
Variable molecule = "ts.xyz";
Variable charge   = 0;
Variable multi    = 1;

# --- Solvation ---
Variable gas_geom   = 0;  # 1 = gas phase
Variable xtb_method = "--gfn2";
Variable xtb_solv   = "--cosmo chloroform";
Variable solv_tsopt = "SMD(diethylether)";

# --- Methods ---
Variable method_copt  = "XTB2";                       # preopt xtb engine
Variable param_copt   = "TightSCF";                   # SCF / grid / RI

Variable method_tsopt = "B3LYP D3BJ";                 # functional keyword
Variable basis_tsopt  = "def2-SVP def2/J";            # orbital + aux basis
Variable param_tsopt  = "TightSCF DEFGRID3 RIJCOSX";  # SCF / grid / RI

# --- Loop controls ---
Variable MaxNTriesPre      = 1;
Variable MaxNTries         = 20;
Variable Cutoff            = -50.0;                        # imaginary-freq threshold (cm^-1)
Variable scaling           = 0.25;                         # FollowNormalMode step
Variable NNegativeTargetCO = 2;
Variable NNegativeTargetTS = 1;

# --- GOAT controls ---
Variable var_goat      = "GOAT";
Variable goat_method   = "XTB";
Variable goat_base     = "ts_conf_search";
Variable goat_minxyz   = "ts_conf_search.globalminimum.xyz";
Variable goat_nworkers = 6;

# --- Files ---
Variable myFilename = "geom.xyz";

# =============================================================
# Internals
# =============================================================
If (gas_geom = 1) Then
  solv_tsopt = "";
  xtb_solv   = "";
EndIf

Variable E1_el, ZPE1, H1, S1, G1, Corr;
Variable StepNo    = 0;
Variable StepNo_TS = -1;

Geometry myGeom;
Variable freqs, modes;
Variable res = -1;

Variable NNegative = 0;
Variable minfreq   = 0.0;
Variable minIndex  = -1;

Variable COPT_Done, TS_Done, AbortRun;

timer jobtimer;

# =============================================================
# Job 01 - GOAT constrained conformer search
# =============================================================
jobtimer.start();

New_Step
  %base "&{goat_base}"
  ! &{var_goat} &{goat_method}
  %xtb
    XTBINPUTSTRING "&{xtb_method} &{xtb_solv}"
  end
  %goat
    NWORKERS &{goat_nworkers}
  end
  %geom
    Constraints
      {B 0 1 C}
      {B 0 2 C}
    end
  end
  *xyzfile &{charge} &{multi} &{molecule}
Step_End
StepNo = StepNo + 1;

Sys_cmd("cp %s %s", goat_minxyz, myFilename);

Print("=== Job01 complete: GOAT done. Global minimum staged as %s ===\n", myFilename);

jobtimer.stop();
Print("[TIMING] Job01: %.2lf s elapsed (cumulative %.2lf s)\n", jobtimer.last(), jobtimer.total());
jobtimer.start();

# =============================================================
# Job 02 - Constrained pre-opt loop
# =============================================================
For itry From 1 To MaxNTriesPre Do

  New_Step
    ! &{method_copt} Opt Freq &{param_copt}
    %xtb
      XTBINPUTSTRING "&{xtb_method} &{xtb_solv}"
    end
    %geom
      Constraints
        {B 0 1 C}
        {B 0 2 C}
      end
    end
    *xyzfile &{charge} &{multi} &{myFilename}
  Step_End

  StepNo = StepNo + 1;

  res = freqs.readProperty(propertyName="THERMO_FREQS");
  If (res < 0) Then
    Print("Job02: THERMO_FREQS unavailable (step did not converge). Ending run.\n");
    goto AbortRun;
  EndIf

  NNegative = 0;
  minfreq   = 0.0;
  minIndex  = -1;

  For ifreq From 0 To freqs.GetSize()-1 Do
    If (freqs[ifreq] < Cutoff) Then
      NNegative = NNegative + 1;
      If (freqs[ifreq] < minfreq) Then
        minfreq  = freqs[ifreq];
        minIndex = ifreq;
      EndIf
    EndIf
  EndFor

  Print("Job02 Iter %d: Nimag = %d (lowest = %lf cm^-1)\n", itry, NNegative, minfreq);

  If (NNegative = 0) Then
    Print("Job02 COPT: no imaginary frequencies - geometry is not TS-like. Ending Run.\n");
    goto AbortRun;
  EndIf

  If (NNegative <= NNegativeTargetCO) Then
    goto COPT_Done;
  EndIf

  myGeom.Read();
  res = modes.readProperty(propertyName="HESSIAN_MODES");
  myGeom.FollowNormalMode(vibrationSN=minIndex+1, scalingFactor=scaling);
  myGeom.WriteXYZFile(filename=myFilename);

EndFor

COPT_Done:

myGeom.Read();
myGeom.WriteXYZFile(filename="Job01_COPT_final.xyz");

Sys_cmd("cp *_Compound_%d.hess copt_seed.hess", StepNo);

Print("\n=== Job02 complete: constrained preopt finished (lowest = %lf cm^-1) ===\n", minfreq);

jobtimer.stop();
Print("[TIMING] Job02: %.2lf s elapsed (cumulative %.2lf s)\n", jobtimer.last(), jobtimer.total());
jobtimer.start();

# =============================================================
# Job 03 - TS optimization loop
# =============================================================
For itry From 1 To MaxNTries Do

  If (itry = 1) Then
    Read_Geom(StepNo);
    New_Step
      ! OptTS Freq SlowConv &{method_tsopt} &{basis_tsopt} &{param_tsopt} &{solv_tsopt}
      %geom
        InHess     Read
        InHessName "copt_seed.hess"
        Recalc_Hess 10
        MaxIter     300
      end
    Step_End
  Else
    ReadMOs(StepNo);
    New_Step
      ! OptTS Freq SlowConv &{method_tsopt} &{basis_tsopt} &{param_tsopt} &{solv_tsopt}
      %geom
        InHess     Read
        InHessName "ts_seed.hess"
        Recalc_Hess 10
        MaxIter     300
      end
      *xyzfile &{charge} &{multi} &{myFilename}
    Step_End
  EndIf

  StepNo = StepNo + 1;

  Sys_cmd("cp *_Compound_%d.hess ts_seed.hess", StepNo);

  res = freqs.readProperty(propertyName="THERMO_FREQS");
  If (res < 0) Then
    Print("Job03: THERMO_FREQS unavailable (step did not converge). Ending run.\n");
    goto AbortRun;
  EndIf

  NNegative = 0;
  minfreq   = 0.0;
  minIndex  = -1;

  For ifreq From 0 To freqs.GetSize()-1 Do
    If (freqs[ifreq] < Cutoff) Then
      NNegative = NNegative + 1;
      If (freqs[ifreq] < minfreq) Then
        minfreq  = freqs[ifreq];
        minIndex = ifreq;
      EndIf
    EndIf
  EndFor

  Print("Job03 Iter %d: Nimag = %d (lowest = %lf cm^-1)\n", itry, NNegative, minfreq);

  If (NNegative = NNegativeTargetTS) Then
    goto TS_Done;
  ElseIf (NNegative = 0) Then
    Print("Job03 TS: no imaginary frequencies - geometry is a minimum, not a TS. Ending Run.\n");
    goto AbortRun;
  EndIf

  myGeom.Read();
  res = modes.readProperty(propertyName="HESSIAN_MODES");
  myGeom.FollowNormalMode(vibrationSN=minIndex+1, scalingFactor=scaling);
  myGeom.WriteXYZFile(filename=myFilename);

EndFor

TS_Done:

StepNo_TS = StepNo;
myGeom.Read();
myGeom.WriteXYZFile(filename="Job02_TS_final.xyz");

Print("\n=== Job03 complete: TS optimization finished (lowest = %lf cm^-1) ===\n", minfreq);

jobtimer.stop();
Print("[TIMING] Job03: %.2lf s elapsed (cumulative %.2lf s)\n", jobtimer.last(), jobtimer.total());

# --- Thermochemistry ---
res = E1_el.readProperty(propertyName="THERMO_ELEC_ENERGY");
If (res < 0) Then
  Print("Job03: THERMO_ELEC_ENERGY unavailable (step did not converge). Ending run.\n");
  goto AbortRun;
EndIf
res = ZPE1.readProperty(propertyName="THERMO_ZPE");
res = H1.readProperty(propertyName="THERMO_ENTHALPY_H");
res = S1.readProperty(propertyName="THERMO_ENTROPY_S");
res = G1.readProperty(propertyName="THERMO_FREE_ENERGY_G");
Corr = G1 - E1_el;

Print("\n");
Print("==================== Thermochemistry ====================\n");
Print("  E1_el   = %20.10lf  Eh\n",   E1_el);
Print("  ZPE     = %20.10lf  Eh\n",   ZPE1);
Print("  H1      = %20.10lf  Eh\n",   H1);
Print("  S1      = %20.10lf  Eh/K\n", S1);
Print("  G1      = %20.10lf  Eh\n",   G1);
Print("  Corr    = %20.10lf  Eh\n",   Corr);
Print("=========================================================\n");

AbortRun:

EndRun
